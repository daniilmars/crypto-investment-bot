# Ignore Git files
.git
.gitignore

# Ignore Docker files
Dockerfile
.dockerignore

# Ignore Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore test files and cache
tests/
.pytest_cache/

# Ignore documentation and local data
README.md
SCREENING_REPORT.md
docs/
data/
*.db

# Ignore dev-only files
# scripts/ kept in image — calibration + utility scripts run inside container
requirements-dev.txt

# Note: config/settings.yaml is generated during CI deploy and must NOT be ignored
