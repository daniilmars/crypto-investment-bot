# ----------------------------------------------------
# API Keys and Configuration for the Crypto Bot
# ----------------------------------------------------
#
# INSTRUCTIONS:
# 1. Rename this file from 'settings.yaml.example' to 'settings.yaml'.
# 2. Fill in your actual API keys and settings below.
# 3. IMPORTANT: The 'settings.yaml' file is listed in .gitignore and will NOT be committed.
#
# ----------------------------------------------------

# -- GCP Billing Settings --
# Configuration for the /gcosts command.
gcp_billing:
  enabled: true
  # Find this in your GCP Console under 'Billing' -> 'Account Management'.
  # It typically looks like '012345-ABCDEF-GHIJKL'.
  billing_account_id: "YOUR_GCP_BILLING_ACCOUNT_ID"

# -- Notification Settings --
# Choose your preferred notification service.
# You can enable multiple services.

notification_services:
  telegram:
    enabled: true
    token: "YOUR_TELEGRAM_BOT_TOKEN"  # Get from @BotFather on Telegram
    chat_id: "YOUR_TELEGRAM_CHAT_ID"      # Your personal chat ID or a group/channel ID
    # A list of numeric user IDs who are allowed to use sensitive commands like /gcosts.
    # You can get your ID by messaging @userinfobot on Telegram.
    authorized_user_ids:
      - 123456789 # Replace with your Telegram User ID

  pushover:
    enabled: false
    user_key: "YOUR_PUSHOVER_USER_KEY"
    api_token: "YOUR_PUSHOVER_API_TOKEN"

# -- API Keys for Data Sources --
# Add the API keys for the data sources you want to use.

api_keys:
  binance:
    api_key: "YOUR_BINANCE_API_KEY"
    api_secret: "YOUR_BINANCE_API_SECRET"
  gemini: "YOUR_GEMINI_API_KEY"
  alpha_vantage: "YOUR_ALPHA_VANTAGE_API_KEY"
  lunarcrush: "YOUR_LUNARCRUSH_API_KEY"
  glassnode: "YOUR_GLASSNODE_API_KEY"
  news_api: "YOUR_NEWS_API_KEY"

# -- General Bot Settings --
settings:
  # Crypto and stock watch lists are loaded from config/watch_list.yaml.
  # Override with env vars WATCH_LIST / STOCK_WATCH_LIST if needed.

  # How often the bot should run its analysis cycle, in minutes.
  run_interval_minutes: 15

  # -- Technical Indicator Settings --
  # Period for Simple Moving Average (SMA) calculation.
  sma_period: 20
  # RSI overbought threshold (e.g., 70 for overbought).
  rsi_overbought_threshold: 70
  # RSI oversold threshold (e.g., 30 for oversold).
  rsi_oversold_threshold: 30

  # -- Telegram Bot Settings --
  # The number of hours to look back for the /status report.
  status_report_hours: 24

  # -- Trading Settings --
  # Enable or disable paper trading mode. If true, no real trades will be placed.
  paper_trading: true
  # Initial capital for paper trading simulation.
  paper_trading_initial_capital: 10000.0

  # -- Risk Management Settings --
  # Percentage of total capital to risk per trade (e.g., 0.01 for 1%).
  trade_risk_percentage: 0.01
  # Percentage below entry price to set a stop-loss (e.g., 0.02 for 2%).
  stop_loss_percentage: 0.02
  # Percentage above entry price to set a take-profit (e.g., 0.05 for 5%).
  take_profit_percentage: 0.05
  # Maximum number of concurrent open positions.
  max_concurrent_positions: 3

  # -- Regular Status Update Settings --
  regular_status_update:
    enabled: true
    interval_hours: 1

  # -- News Analysis Settings --
  news_analysis:
    enabled: true
    # Use Gemini 2.0 Flash for per-article sentiment scoring (replaces VADER, DB-cached)
    use_gemini_scoring: true
    # Volume spike: trigger Gemini if current_volume > previous_volume * multiplier
    volume_spike_multiplier: 3.0
    # Sentiment shift: trigger Gemini if abs(current - previous) >= threshold
    sentiment_shift_threshold: 0.3
    # VADER sentiment thresholds for signal scoring
    sentiment_buy_threshold: 0.15
    sentiment_sell_threshold: -0.15
    # Minimum Gemini confidence to override VADER
    min_gemini_confidence: 0.6

  # -- News Scraper Daemon Settings --
  # Continuous scraper with tiered intervals (replaces launchd batch approach)
  news_scraper_daemon:
    rss_interval_seconds: 300        # 5 minutes
    web_interval_seconds: 900        # 15 minutes
    deep_interval_seconds: 1800      # 30 minutes
    dedup_cache_hours: 48
    chrome_mcp:
      enabled: false                 # Set true to use Chrome MCP for web scraping
      timeout_seconds: 180
      fallback_to_bs4: true

  # -- Stock Trading Settings --
  # Stock watch list is loaded from config/watch_list.yaml (US + EU + Asia).
  stock_trading:
    enabled: false
    max_concurrent_positions: 8
    sma_period: 20
    rsi_period: 14
    rsi_overbought_threshold: 70
    rsi_oversold_threshold: 30
    pe_ratio_buy_threshold: 25
    pe_ratio_sell_threshold: 40
    earnings_growth_sell_threshold: -10
    volume_spike_multiplier: 1.5
